---
import Layout from '../layouts/Layout.astro';

const features = [
  {
    icon: '👥',
    title: 'Compra en grupo',
    text: 'Crea grupos con tu familia o compañeros de piso y comparte una misma lista de la compra.',
  },
  {
    icon: '🛒',
    title: 'Carrito compartido',
    text: 'Un carrito activo por grupo. Lo que añade uno, lo ven todos al instante.',
  },
  {
    icon: '🔄',
    title: 'En tiempo real',
    text: 'Marca productos según los vas cogiendo y todo el grupo ve el progreso al momento.',
  },
  {
    icon: '🥫',
    title: 'Catálogo de Mercadona',
    text: 'Busca productos reales con su precio y foto, y añádelos a la lista en dos toques.',
  },
  {
    icon: '🔗',
    title: 'Invita con un enlace',
    text: 'Comparte un enlace y quien lo abra entra directo a tu grupo. Sin fricción.',
  },
  {
    icon: '💸',
    title: 'Total estimado',
    text: 'Ve cuánto suma la cesta antes de llegar a caja. Sin sorpresas.',
  },
];
---

<Layout>
  <!-- Hero -->
  <section class="hero">
    <div class="container hero-inner">
      <span class="eyebrow">La compra compartida, sin líos</span>
      <h1>¿Qué falta?</h1>
      <p class="lead">
        La app para organizar la compra en grupo. Lista compartida en tiempo real,
        carrito por grupos y catálogo de Mercadona. Tú y los tuyos, siempre sincronizados.
      </p>
      <div class="hero-cta" id="descargar">
        <a class="btn-primary" href="#">
          <span></span> Descargar en App Store
        </a>
        <span class="hero-note">Próximamente en iOS</span>
      </div>
    </div>
  </section>

  <!-- Features -->
  <section class="features container">
    <h2>Todo lo que necesitas para no olvidar nada</h2>
    <div class="feature-grid">
      {features.map((f) => (
        <article class="feature-card">
          <span class="feature-icon">{f.icon}</span>
          <h3>{f.title}</h3>
          <p>{f.text}</p>
        </article>
      ))}
    </div>
  </section>

  <!-- Closing CTA -->
  <section class="container">
    <div class="cta-banner">
      <h2>Deja de preguntar "¿compraste el pan?"</h2>
      <p>QuéFalta mantiene a todo el grupo en la misma página. Literalmente.</p>
      <a class="btn-primary inverse" href="#descargar">Descargar gratis</a>
    </div>
  </section>

  <style>
    .hero { padding: 56px 0 40px; }
    .hero-inner { max-width: 720px; }
    .eyebrow {
      display: inline-block;
      font-size: 12px;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 1.6px;
      color: var(--accent);
      margin-bottom: 14px;
    }
    h1 {
      font-size: clamp(44px, 9vw, 84px);
      font-weight: 700;
      letter-spacing: -2px;
      line-height: 1;
    }
    .lead {
      font-size: clamp(16px, 2.4vw, 20px);
      color: var(--ink-soft);
      margin-top: 20px;
      max-width: 600px;
    }
    .hero-cta { margin-top: 32px; display: flex; align-items: center; gap: 16px; flex-wrap: wrap; }
    .hero-note { font-size: 13px; color: var(--ink-soft); }

    .btn-primary {
      display: inline-flex;
      align-items: center;
      gap: 9px;
      background: var(--accent);
      color: var(--white);
      padding: 14px 22px;
      border-radius: 12px;
      font-weight: 600;
      font-size: 15px;
      transition: transform 0.15s ease;
    }
    .btn-primary:hover { transform: translateY(-2px); }
    .btn-primary.inverse { background: var(--white); color: var(--accent); }

    .features { padding: 48px 24px; }
    .features h2 {
      font-size: clamp(24px, 4vw, 34px);
      letter-spacing: -0.8px;
      max-width: 520px;
      margin-bottom: 32px;
    }
    .feature-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
      gap: 16px;
    }
    .feature-card {
      background: var(--white);
      border: 1px solid var(--border);
      border-radius: 16px;
      padding: 24px;
    }
    .feature-icon { font-size: 30px; display: block; margin-bottom: 12px; }
    .feature-card h3 { font-size: 17px; margin-bottom: 6px; letter-spacing: -0.3px; }
    .feature-card p { font-size: 14.5px; color: var(--ink-soft); }

    .cta-banner {
      background: var(--accent);
      color: var(--white);
      border-radius: 24px;
      padding: 48px 32px;
      text-align: center;
      margin-top: 16px;
    }
    .cta-banner h2 { font-size: clamp(24px, 4vw, 36px); letter-spacing: -0.8px; }
    .cta-banner p { margin: 12px 0 24px; opacity: 0.9; font-size: 16px; }
  </style>
</Layout>
