---
import Layout from '../../layouts/Layout.astro';
import { STORES, UPDATED } from '../../data/supermercados.js';

// Página de detalle de cada supermercado (plan AEO F2). La plantilla es común
// pero TODO el contenido (intro, datos, FAQs, metas) es único por súper y vive
// en src/data/supermercados.js — editar allí, no aquí.

export function getStaticPaths() {
  return STORES.map((s) => ({ params: { store: s.slug }, props: { store: s } }));
}

const { store } = Astro.props;
const others = STORES.filter((s) => s.slug !== store.slug);

// Mismo texto que el visible (requisito de Google para FAQPage).
const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  inLanguage: 'es',
  dateModified: UPDATED,
  mainEntity: store.faqs.map((f) => ({
    '@type': 'Question',
    name: f.q,
    acceptedAnswer: { '@type': 'Answer', text: f.a },
  })),
};

// Qué puedes hacer con cualquier súper de la app (común a las 6 páginas).
const ACCIONES = [
  'Buscar en todo el catálogo y añadir productos a la lista con un toque.',
  'Compartir la cesta con tu grupo: todos ven los cambios al instante.',
  'Ver la cesta ordenada por zonas del supermercado (fruta y verdura, frescos, congelados…) para recorrer la tienda una sola vez.',
  'Guardar favoritos y repetirlos en un toque desde el inicio.',
  'Elegir qué supermercados ves en tu catálogo: solo este, o combinado con los demás.',
];

// Fecha legible en español (ej. "12 de julio de 2026").
const fmt = (iso) => {
  const [y, m, d] = iso.split('-').map(Number);
  return new Date(y, m - 1, d).toLocaleDateString('es-ES', {
    day: 'numeric', month: 'long', year: 'numeric',
  });
};
---

<Layout
  title={store.title}
  description={store.description}
  jsonld={faqSchema}
>
  <section class="st container">
    <header class="st-head">
      <img class="st-logo" src={store.logo} alt="" width="44" height="44" />
      <span class="st-eyebrow">Supermercados</span>
      <h1 class="st-title">{store.name} en QuéFalta</h1>
      <p class="st-lead">{store.intro}</p>
      <p class="st-updated">
        Actualizado el <time datetime={UPDATED}>{fmt(UPDATED)}</time>
      </p>
    </header>

    <section class="st-block">
      <h2 class="st-h2">Qué encuentras de {store.name} en QuéFalta</h2>
      <ul class="st-list">
        {store.datos.map((d) => <li>{d}</li>)}
      </ul>
    </section>

    <section class="st-block">
      <h2 class="st-h2">Qué puedes hacer</h2>
      <ul class="st-list">
        {ACCIONES.map((a) => <li>{a}</li>)}
      </ul>
    </section>

    <section class="st-block">
      <h2 class="st-h2">Preguntas sobre {store.name}</h2>
      <div class="st-faqs">
        {store.faqs.map((f) => (
          <article class="st-faq">
            <h3 class="st-q">{f.q}</h3>
            <p class="st-a" set:html={f.a} />
          </article>
        ))}
      </div>
      <p class="st-morefaq">
        Más respuestas en las <a href="/preguntas">preguntas frecuentes</a>.
      </p>
    </section>

    <p class="st-disclaimer">
      Los precios y datos de {store.name} mostrados en QuéFalta proceden de su
      web pública, son orientativos y pueden variar. QuéFalta no está afiliada,
      asociada ni patrocinada por {store.name}.
    </p>

    <section class="st-others">
      <h2 class="st-h2">También en QuéFalta</h2>
      <div class="st-chips">
        {others.map((s) => (
          <a class="st-chip" href={`/supermercados/${s.slug}`}>
            <img src={s.logo} alt="" width="22" height="22" loading="lazy" />
            {s.name}
          </a>
        ))}
      </div>
    </section>

    <aside class="st-cta">
      <p>Gratis, sin anuncios y con la lista compartida en tiempo real.</p>
      <a class="st-cta-btn" href="https://apps.apple.com/es/app/qu%C3%A9falta/id6777720373">
        Descárgala en el App Store
      </a>
    </aside>
  </section>

  <style>
    .st { max-width: 760px; padding-top: 36px; }

    .st-head { text-align: center; max-width: 640px; margin: 48px auto 0; }
    .st-logo { width: 44px; height: 44px; object-fit: contain; margin-bottom: 14px; }
    :global([data-theme="dark"]) .st-logo {
      background: #fff; border-radius: 9px; padding: 4px; box-sizing: content-box;
    }
    .st-eyebrow {
      display: block; font-size: 12.5px; font-weight: 700;
      letter-spacing: 0.02em; color: var(--accent);
    }
    .st-title {
      font-family: var(--geo); font-weight: 800; letter-spacing: -0.035em;
      line-height: 1.04; font-size: clamp(28px, 4.6vw, 44px);
      margin-top: 12px; color: var(--ink);
    }
    .st-lead {
      color: var(--ink-soft); font-size: clamp(16px, 1.6vw, 18px);
      line-height: 1.55; margin: 16px auto 0;
    }
    .st-updated { margin-top: 14px; font-size: 13px; color: var(--ink-faint); }

    .st-block { margin-top: 44px; }
    .st-h2 {
      font-family: var(--geo); font-weight: 700; font-size: 21px;
      letter-spacing: -0.02em; color: var(--ink);
    }
    .st-list { margin: 14px 0 0 0; padding-left: 22px; display: grid; gap: 8px; }
    .st-list li { color: var(--ink-soft); font-size: 15.5px; line-height: 1.55; }

    .st-faqs { margin-top: 14px; display: grid; gap: 12px; }
    .st-faq {
      background: var(--surface); border: 1px solid var(--border);
      border-radius: 18px; padding: 20px 22px;
      box-shadow: 0 1px 2px rgba(17, 17, 20, 0.04), 0 4px 16px rgba(17, 17, 20, 0.05);
    }
    .st-q {
      font-family: var(--geo); font-weight: 700; font-size: 16.5px;
      letter-spacing: -0.015em; line-height: 1.3; color: var(--ink);
    }
    .st-a { color: var(--ink-soft); font-size: 15px; line-height: 1.6; margin-top: 8px; }
    .st-a :global(a) { color: var(--accent); font-weight: 600; }
    .st-a :global(a:hover) { text-decoration: underline; }
    .st-morefaq { margin-top: 14px; font-size: 14.5px; color: var(--ink-soft); }
    .st-morefaq a { color: var(--accent); font-weight: 600; }

    .st-disclaimer {
      font-size: 13px; color: var(--ink-faint);
      margin-top: 36px; line-height: 1.5;
    }

    .st-others { margin-top: 40px; }
    .st-chips { display: flex; flex-wrap: wrap; gap: 10px; margin-top: 14px; }
    .st-chip {
      display: inline-flex; align-items: center; gap: 8px;
      background: var(--surface); border: 1px solid var(--border);
      border-radius: 980px; padding: 9px 16px 9px 11px;
      font-size: 14px; font-weight: 600; color: var(--ink);
      transition: transform 0.18s cubic-bezier(0.22, 0.61, 0.36, 1);
    }
    .st-chip:hover { transform: translateY(-2px); }
    .st-chip img { width: 22px; height: 22px; object-fit: contain; }
    :global([data-theme="dark"]) .st-chip img {
      background: #fff; border-radius: 5px; padding: 2px; box-sizing: content-box;
    }

    .st-cta {
      margin-top: 44px; text-align: center;
      background: var(--paper-2); border: 1px solid var(--border);
      border-radius: 20px; padding: 28px 26px;
    }
    .st-cta p { color: var(--ink-soft); font-size: 15.5px; line-height: 1.6; }
    .st-cta-btn {
      display: inline-block; margin-top: 16px;
      background: var(--accent); color: #fff !important; font-weight: 700;
      font-size: 15px; padding: 12px 22px; border-radius: 12px;
      transition: opacity 0.15s;
    }
    .st-cta-btn:hover { opacity: 0.9; }
  </style>
</Layout>
