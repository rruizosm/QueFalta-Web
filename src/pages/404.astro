---
import Layout from '../layouts/Layout.astro';
// Página de error 404. Amplify la sirve con la regla de redirección
// `/<*> → /404.html (404)` (va detrás del rewrite de /join/:id en la consola).
// Con noindex: una página de error no debe aparecer en buscadores.
---

<Layout
  title="Página no encontrada — QuéFalta"
  description="La página que buscas no existe o ha cambiado de dirección."
  noindex
>
  <section class="nf container">
    <span class="nf-code">404</span>
    <h1>Esta página no existe</h1>
    <p class="nf-lead">
      Puede que el enlace haya cambiado o que la dirección esté mal escrita.
    </p>
    <div class="nf-actions">
      <a class="nf-btn" href="/">Volver al inicio</a>
      <a class="nf-link" href="/novedades">Ver las novedades</a>
    </div>
  </section>

  <style>
    .nf {
      max-width: 560px;
      padding-top: 72px;
      padding-bottom: 24px;
      text-align: center;
    }
    .nf-code {
      display: inline-block;
      font-size: 13px;
      font-weight: 700;
      letter-spacing: 1.6px;
      color: var(--accent);
      background: var(--accent-light);
      border-radius: 999px;
      padding: 6px 14px;
      margin-bottom: 16px;
    }
    h1 { font-size: clamp(30px, 6vw, 44px); letter-spacing: -1.2px; line-height: 1.05; }
    .nf-lead { color: var(--ink-soft); margin-top: 14px; font-size: 16px; }
    .nf-actions {
      margin-top: 28px;
      display: flex;
      flex-direction: column;
      gap: 14px;
      align-items: center;
    }
    .nf-btn {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      padding: 13px 24px;
      border-radius: 12px;
      font-weight: 600;
      font-size: 15px;
      background: var(--accent);
      color: var(--white);
    }
    .nf-link { font-size: 14px; color: var(--ink-soft); text-decoration: underline; }
    .nf-link:hover { color: var(--accent); }
  </style>
</Layout>
