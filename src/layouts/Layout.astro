---
import CookieConsent from '../components/CookieConsent.astro';
import SiteNav from '../components/SiteNav.astro';

interface Props {
  title?: string;
  description?: string;
  /** Oculta la cabecera y el pie genéricos (la landing trae su propio chrome). */
  bare?: boolean;
  /** Imagen para previews al compartir (ruta absoluta dentro del sitio). */
  image?: string;
}
const {
  title = 'QuéFalta — La compra compartida, sin líos',
  description = 'Organiza la compra en grupo: lista compartida en tiempo real, carrito por grupos y catálogo de seis supermercados. ¿Qué falta?',
  bare = false,
  image = '/og.png',
} = Astro.props;
const canonical = new URL(Astro.url.pathname, Astro.site).href;
const ogImage = new URL(image, Astro.site).href;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <meta property="og:site_name" content="QuéFalta" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    <meta property="og:locale" content="es_ES" />
    <meta property="og:image" content={ogImage} />
    <!-- Dimensiones explícitas: WhatsApp/Telegram/iMessage reservan la tarjeta
         grande sin tener que descargar la imagen primero (las OG miden 1200×630). -->
    <meta property="og:image:type" content="image/png" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content={title} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:image" content={ogImage} />
    <meta name="theme-color" content="#ffffff" />
    <link rel="sitemap" href="/sitemap-index.xml" />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700&family=Newsreader:ital,opsz,wght@0,6..72,400;0,6..72,500;1,6..72,400;1,6..72,500;1,6..72,600&family=Mulish:wght@400;500;600;700;800&display=swap"
      rel="stylesheet"
    />
    <title>{title}</title>
    <!-- Aplica el tema (claro/oscuro) y el color de acento guardados antes de
         pintar, para evitar el parpadeo y mantenerlos entre páginas. -->
    <script is:inline>
      (function () {
        try {
          var el = document.documentElement;
          if (localStorage.getItem('qf-theme') === 'dark') el.dataset.theme = 'dark';
          var a = localStorage.getItem('qf-accent');
          if (a) {
            var n = parseInt(a.slice(1), 16);
            var r = (n >> 16) & 255, g = (n >> 8) & 255, b = n & 255;
            el.style.setProperty('--accent', a);
            el.style.setProperty('--accent-soft', 'rgba(' + r + ',' + g + ',' + b + ',0.14)');
            el.style.setProperty('--accent-light', 'rgba(' + r + ',' + g + ',' + b + ',0.10)');
          }
        } catch (e) {}
      })();
    </script>
  </head>
  <body>
    {!bare && <SiteNav />}

    <main>
      <slot />
    </main>

    {!bare && (
      <footer class="site-footer">
        <div class="footer-inner">
          <a href="/" class="footer-brand">
            <img src="/quefalta-logo-blue.png" alt="" class="footer-logo" width="24" height="24" />
            <span class="footer-word">Qué<span>Falta</span></span>
          </a>
          <nav class="footer-links">
            <a href="/novedades">Novedades</a>
            <a href="/apoyar">Apoyar</a>
            <a href="/privacidad">Privacidad</a>
            <a href="/condiciones">Condiciones</a>
            <a href="/cookies">Cookies</a>
            <a href="mailto:contacto@quefalta.es">Contacto</a>
          </nav>
          <p class="footer-copy">© {new Date().getFullYear()} QuéFalta · Hecho en España</p>
        </div>
      </footer>
    )}

    <CookieConsent />

    <style is:global>
      :root {
        --accent: #2f6cb5;
        --accent-light: rgba(47, 108, 181, 0.10);
        --accent-soft: #e9f1fa;
        --ink: #111114;
        --ink-soft: #5d5d66;
        --ink-faint: #9a9aa3;
        --paper: #ffffff;
        --paper-2: #f5f5f7;
        --surface: #ffffff;
        --white: #ffffff;
        --border: #e7e7ec;
        --ok: #2faa4f;
        --geo: 'Space Grotesk', system-ui, sans-serif;
        --serif: 'Newsreader', Georgia, serif;
        --ease: cubic-bezier(0.22, 0.61, 0.36, 1);
      }

      /* Modo oscuro: redefine los tokens de color; el resto del CSS los usa vía
         var(). Se activa con [data-theme="dark"] en <html> (lo pone el script de
         arriba). Vive aquí (global) para que TODAS las páginas —incluidas las
         legales, que no cargan landing.css— hereden el tema oscuro. */
      [data-theme="dark"] {
        --ink: #f1f1f4;
        --ink-soft: #b4b4be;
        --ink-faint: #7e7e89;
        --paper: #0f0f14;
        --paper-2: #16161d;
        --surface: #1b1b23;
        --border: rgba(255, 255, 255, 0.22);
      }

      /* Navbar en modo oscuro (global: aplica en TODAS las páginas, no solo la
         home). El fondo y el CTA del navbar usan colores fijos, así que aquí se
         adaptan; el enlace activo se mantiene en el color de acento. */
      [data-theme="dark"] nav.qf-nav { background: rgba(13, 13, 18, 0.72); }
      [data-theme="dark"] nav.qf-nav .qf-word,
      [data-theme="dark"] nav.qf-nav .qf-word-txt span,
      [data-theme="dark"] nav.qf-nav .qf-nav-link { color: #fff; }
      [data-theme="dark"] nav.qf-nav .qf-nav-cta { background: var(--accent); color: #fff; }
      [data-theme="dark"] nav.qf-nav .qf-nav-link.is-active { color: var(--accent); }

      * { box-sizing: border-box; margin: 0; padding: 0; }

      /* Compensa la barra de navegación fija (61px) al saltar a un ancla,
         para que #top quede arriba del todo y las secciones no se oculten
         tras el navbar. */
      html { scroll-behavior: smooth; scroll-padding-top: 61px; }

      body {
        font-family: var(--geo);
        background: var(--paper);
        color: var(--ink);
        line-height: 1.5;
        -webkit-font-smoothing: antialiased;
        text-rendering: optimizeLegibility;
        /* Sticky footer: en páginas cortas el <main> crece hasta llenar la
           ventana y empuja el pie al fondo, en vez de quedarse a media altura. */
        min-height: 100vh;
        display: flex;
        flex-direction: column;
      }

      main { flex: 1 0 auto; }

      a { color: inherit; text-decoration: none; }

      .site-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 18px 24px;
        max-width: 1080px;
        margin: 0 auto;
      }

      .brand { display: flex; align-items: center; gap: 10px; font-weight: 700; }
      .brand-mark {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 34px;
        height: 34px;
        background: var(--accent);
        color: var(--white);
        border-radius: 9px;
        font-size: 14px;
        font-weight: 700;
        letter-spacing: -0.5px;
      }
      .brand-mark.small { width: 26px; height: 26px; font-size: 11px; border-radius: 7px; }
      .brand-name { font-size: 18px; letter-spacing: -0.3px; }

      .header-cta {
        background: var(--ink);
        color: var(--white);
        padding: 9px 16px;
        border-radius: 10px;
        font-size: 14px;
        font-weight: 600;
      }

      /* Pie idéntico al de la landing (.qf-footer). */
      .site-footer { border-top: 1px solid var(--border); margin-top: 64px; }
      .footer-inner {
        max-width: 1120px;
        margin: 0 auto;
        padding: 40px;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 18px;
        flex-wrap: wrap;
      }
      .footer-brand { display: flex; align-items: center; gap: 9px; font-family: var(--geo); font-weight: 800; letter-spacing: -0.03em; color: var(--ink); }
      .footer-logo { width: 24px; height: 24px; object-fit: contain; display: block; }
      .footer-word span { color: var(--accent); }
      .footer-links { display: flex; gap: 24px; flex-wrap: wrap; }
      .footer-links a { font-size: 14px; color: var(--ink-soft); transition: color 0.15s; }
      .footer-links a:hover { color: var(--accent); }
      .footer-copy { width: 100%; font-size: 12.5px; color: var(--ink-faint); border-top: 1px solid var(--border); padding-top: 20px; }

      @media (max-width: 980px) {
        .footer-inner { padding-left: 24px; padding-right: 24px; flex-direction: column; align-items: flex-start; }
      }

      .container { max-width: 1080px; margin: 0 auto; padding: 0 24px; }
    </style>
  </body>
</html>
